{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "della-admin",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-04",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "admin.dellaapp.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "vars": {
    "SUPABASE_URL": "https://exsoqkvwzzwmaqxkkoab.supabase.co"
  },
  "observability": {
    "enabled": true
  }
}
